{
  "name": "@tyrs-hand/playwright-mcp",
  "version": "0.1.0",
  "description": "Tyrs Browser Bridge and Playwright MCP distribution",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slovx2/playwright-mcp.git"
  },
  "homepage": "https://github.com/slovx2/playwright-mcp",
  "engines": {
    "node": ">=18"
  },
  "author": {
    "name": "Tyrs Hand contributors"
  },
  "license": "Apache-2.0",
  "mcpName": "io.github.slovx2/tyrs-browser-bridge",
  "scripts": {
    "lint": "node update-readme.js",
    "test": "playwright test",
    "ctest": "playwright test --project=chrome",
    "ftest": "playwright test --project=firefox",
    "wtest": "playwright test --project=webkit",
    "dtest": "MCP_IN_DOCKER=1 playwright test --project=chromium-docker",
    "build": "echo OK",
    "bridge:start": "node bridge/src/server.mjs",
    "bridge:test": "node --test bridge/test/*.test.mjs",
    "build-tyrs-bundle": "node scripts/build-tyrs-bundle.mjs",
    "npm-publish": "npm run lint && npm run test && npm publish",
    "docker-build": "docker build --no-cache -t playwright-mcp-dev:latest .",
    "docker-rm": "docker rm playwright-mcp-dev",
    "docker-run": "docker run -it -p 8080:8080 --name playwright-mcp-dev playwright-mcp-dev:latest",
    "roll": "node roll.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "dependencies": {
    "playwright-core": "1.62.0-alpha-1783623505000"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.25.2",
    "@playwright/test": "1.62.0-alpha-1783623505000",
    "@types/node": "24.3.0"
  },
  "bin": {
    "playwright-mcp": "cli.js"
  }
}
